#!/usr/bin/env bash
# Epilog: revoke SSH access for the job's user when their last job ends.
# Adapted from deepops roles/slurm/templates/etc/slurm/epilog.d/41-lastuserjob-ssh
set -ex

# Don't revoke access for permanently-listed users
if grep -q -w "$SLURM_JOB_USER" /etc/slurm/localusers.backup ; then
    exit 0
fi

sed -i "/${SLURM_JOB_USER}/d" /etc/localusers
